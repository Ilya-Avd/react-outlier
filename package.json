{
  "name": "react-outlier",
  "version": "0.1.0",
  "description": "Robust useClickOutside hook for React — handles portals, Shadow DOM, touch, Escape, and more",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/react-outlier.umd.js",
  "module": "./dist/react-outlier.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-outlier.es.js",
      "require": "./dist/react-outlier.umd.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --project tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src demo eslint.config.js",
    "lint:fix": "eslint src demo eslint.config.js --fix"
  },
  "keywords": ["react", "hook", "click-outside", "typescript"],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "jsdom": "^25.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "prettier": "^3.4.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0"
  }
}
